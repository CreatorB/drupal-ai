<div class="ai-chat-widget" data-ai-chat>
  <button class="ai-chat-widget__trigger" data-ai-chat-toggle aria-label="{{ 'Chat with AI'|t }}">
    <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
      <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
    </svg>
    <span class="ai-chat-widget__badge">AI</span>
  </button>

  <div class="ai-chat-widget__panel" data-ai-chat-panel>
    <div class="ai-chat-widget__header">
      <div>
        <strong>{{ 'AI Assistant'|t }}</strong>
        <small>{{ 'Ask about articles, events, or content across the platform'|t }}</small>
      </div>
      <button type="button" data-ai-chat-toggle aria-label="{{ 'Close'|t }}">&times;</button>
    </div>

    <div class="ai-chat-widget__messages" data-ai-chat-messages>
      <div class="chat-message chat-message--bot">
        <p>{{ 'Hello! I can help you find articles, events, and cross-site content. What would you like to explore?'|t }}</p>
        <div class="chat-suggestion-list">
          <button type="button" class="chat-suggestion" data-ai-chat-suggestion="What do you have about kubernetes?">{{ 'Kubernetes content'|t }}</button>
          <button type="button" class="chat-suggestion" data-ai-chat-suggestion="Show me SBF employment content">{{ 'SBF employment'|t }}</button>
          <button type="button" class="chat-suggestion" data-ai-chat-suggestion="Find finance articles about green bonds">{{ 'Green bonds'|t }}</button>
        </div>
      </div>
    </div>

    <form class="ai-chat-widget__input" data-ai-chat-form>
      <label class="visually-hidden" for="ai-chat-input">{{ 'Ask the AI assistant'|t }}</label>
      <input id="ai-chat-input" type="text" placeholder="{{ 'Ask me anything...'|t }}" data-ai-chat-input autocomplete="off">
      <button type="submit" aria-label="{{ 'Send message'|t }}">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </form>
  </div>
</div>
