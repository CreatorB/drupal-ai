<header class="site-header">
  <div class="site-header__inner">
    <a class="site-brand" href="/">{{ brand_markup|raw }}</a>
    <nav class="site-nav" aria-label="{{ 'Primary navigation'|t }}">
      {%- for item in nav_items -%}
        {% if item.url == '/ai-search' %}
          <a href="{{ item.url }}" data-search-trigger>{{ item.label|t }}</a>
        {% else %}
          <a href="{{ item.url }}">{{ item.label|t }}</a>
        {% endif %}
      {%- endfor -%}
    </nav>
    <div class="site-header__utils" aria-label="{{ 'Utility navigation'|t }}">
      <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" aria-label="{{ 'LinkedIn'|t }}"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M6.94 6.5A2.19 2.19 0 1 1 2.56 6.5a2.19 2.19 0 0 1 4.38 0ZM2.8 8.9h4.28V21H2.8V8.9Zm7.04 0h4.1v1.66h.06c.57-1.08 1.97-2.22 4.05-2.22 4.33 0 5.13 2.85 5.13 6.56V21h-4.28v-5.47c0-1.31-.02-3-1.83-3-1.84 0-2.12 1.44-2.12 2.9V21H9.84V8.9Z"/></svg></a>
      <a href="https://x.com/" target="_blank" rel="noopener noreferrer" aria-label="{{ 'X'|t }}"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M18.9 3H21l-6.48 7.42L22 21h-6.9l-5.4-6.84L3.74 21H1.62l7.06-8.08L2 3h7.06l4.86 6.2L18.9 3Zm-1.21 16h1.8L7.1 4.98H5.18L17.69 19Z"/></svg></a>
      <a href="https://www.youtube.com/" target="_blank" rel="noopener noreferrer" aria-label="{{ 'YouTube'|t }}"><svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M21.8 8.04s-.2-1.43-.82-2.06c-.78-.82-1.65-.82-2.05-.87C16.1 5 12 5 12 5s-4.1 0-6.93.11c-.4.05-1.27.05-2.05.87C2.4 6.61 2.2 8.04 2.2 8.04S2 9.72 2 11.41v1.18c0 1.69.2 3.37.2 3.37s.2 1.43.82 2.06c.78.82 1.8.79 2.26.88 1.64.16 6.72.1 6.72.1s4.1 0 6.93-.11c.4-.05 1.27-.05 2.05-.87.62-.63.82-2.06.82-2.06s.2-1.68.2-3.37v-1.18c0-1.69-.2-3.37-.2-3.37ZM9.75 14.9V8.54l6.16 3.18-6.16 3.18Z"/></svg></a>
      <a class="btn-login" href="/user/login"><svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M12 12c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5Zm0 2c-3.34 0-10 1.67-10 5v3h20v-3c0-3.33-6.66-5-10-5Z"/></svg>{{ 'Login'|t }}</a>
      <a class="search-link" href="/ai-search" data-search-trigger aria-label="{{ 'Search'|t }}"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5Zm-6 0A4.5 4.5 0 1 1 14 9.5 4.505 4.505 0 0 1 9.5 14Z"/></svg></a>
    </div>
    <a class="search-link search-link--mobile" href="/ai-search" data-search-trigger aria-label="{{ 'Search'|t }}"><svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5Zm-6 0A4.5 4.5 0 1 1 14 9.5 4.505 4.505 0 0 1 9.5 14Z"/></svg></a>
    <button class="site-nav-toggle" type="button" data-nav-toggle>{{ 'Menu'|t }}</button>
  </div>
</header>
