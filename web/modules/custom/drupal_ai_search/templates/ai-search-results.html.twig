<section class="ai-search-page">
  {% if query %}
    <div class="ai-search-page__mode-toggle">
      <a class="mode-badge mode-badge--ai {{ search_mode != 'keyword' ? 'is-active' : '' }}" href="/ai-search?q={{ query|url_encode }}">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1s-2.73 7.08 0 9.79c2.73 2.71 7.15 2.71 9.88 0A6.99 6.99 0 0 0 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.49 12.65 0L21 3v7.12z"/></svg>
        {{ 'AI Mode'|t }}
      </a>
      <a class="mode-badge mode-badge--keyword {{ search_mode == 'keyword' ? 'is-active' : '' }}" href="/ai-search?q={{ query|url_encode }}&mode=keyword">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        {{ 'Keyword Mode'|t }}
      </a>
    </div>

    {% if search_mode == 'keyword' %}
      <div class="ai-search-page__keyword-insight">
        <div class="ai-insight__header">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
          <strong>{{ 'Keyword-only mode'|t }}</strong>
        </div>
        <p>{{ 'Searching by exact text match only. No AI interpretation. Compare with AI Mode to see the difference.'|t }}</p>
        {% if filters.keyword_tokens is not empty %}
          <div class="ai-insight__parsed">
            {% for token in filters.keyword_tokens %}
              <span class="parsed-tag parsed-tag--keyword">{{ token }}</span>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% elseif ai_status == 'ok' %}
      <div class="ai-search-page__ai-insight">
        <div class="ai-insight__header">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1s-2.73 7.08 0 9.79c2.73 2.71 7.15 2.71 9.88 0A6.99 6.99 0 0 0 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.49 12.65 0L21 3v7.12z"/></svg>
          <strong>{{ 'AI understood your query'|t }}</strong>
        </div>
        {% if summary %}
          <p>{{ summary }}</p>
        {% endif %}
        <div class="ai-insight__parsed">
          {% if filters.content_type %}
            <span class="parsed-tag">{{ 'Type'|t }}: {{ filters.content_type }}</span>
          {% endif %}
          {% if filters.keyword_tokens is not empty %}
            {% for token in filters.keyword_tokens %}
              <span class="parsed-tag">{{ token }}</span>
            {% endfor %}
          {% endif %}
          {% if filters.language and filters.language != 'null' %}
            <span class="parsed-tag">{{ 'Lang'|t }}: {{ filters.language }}</span>
          {% endif %}
        </div>
      </div>
    {% elseif ai_status == 'error' %}
      <div class="ai-search-page__error">
        <strong>{{ 'AI search is temporarily unavailable.'|t }}</strong>
        <p>{{ 'The AI provider returned an error. Results below use basic keyword matching instead.'|t }}</p>
        {% if ai_error %}
          <details>
            <summary>{{ 'Technical details'|t }}</summary>
            <p>{{ ai_error }}</p>
          </details>
        {% endif %}
      </div>
    {% elseif ai_status == 'fallback' %}
      <div class="ai-search-page__notice">
        {{ 'Using keyword-based search. AI provider is not configured.'|t }}
      </div>
    {% endif %}
  {% else %}
    <p class="ai-search-page__summary">{{ 'Type a natural language question to search with AI.'|t }}</p>
  {% endif %}

  <div class="ai-search-page__results">
    {% if query %}
      <p class="ai-search-page__count">{{ results|length }} {{ 'results found'|t }}</p>
    {% endif %}
    {% if results is empty and query %}
      <p class="ai-search-page__empty">{{ 'No matching content found. Try a different query.'|t }}</p>
    {% else %}
      {% for item in results %}
        <article class="ai-search-result {{ item.is_external ? 'ai-search-result--external' : '' }}">
          {% if item.source_label is defined and item.source_label %}
            <span class="source-badge source-badge--{{ item.source }}">{{ item.source_label }}</span>
          {% endif %}
          <h2>
            <a href="{{ item.url }}"{{ item.is_external ? ' target="_blank" rel="noopener noreferrer"' : '' }}>
              {{ item.title }}
              {% if item.is_external %}
                <svg class="external-icon" viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M19 19H5V5h7V3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
              {% endif %}
            </a>
          </h2>
          {% if item.date is defined and item.date %}
            <p class="ai-search-result__meta">{{ item.date }}{% if item.type %} | {{ item.type|replace({'_': ' '})|title }}{% endif %}</p>
          {% endif %}
          {% if item.summary %}
            <p>{{ item.summary }}</p>
          {% endif %}
        </article>
      {% endfor %}
    {% endif %}
  </div>
</section>
