# OpenCode API
OPENCODE_API_KEY=replace-with-your-opencode-api-key
OPENCODE_API_ENDPOINT=https://api.opencode.dev/v1
OPENCODE_MODEL=minimax-m2.5-free
OPENCODE_FALLBACK_MODEL=mimo-v2-pro-free
AI_PROVIDER_NAME=OpenCode
AI_PROVIDER_SITE_URL=https://primary.ddev.site
AI_PROVIDER_APP_NAME=Drupal AI Multisite Demo

# Alternative free/openai-compatible providers for demo use
# OpenRouter example:
# OPENCODE_API_KEY=replace-with-your-openrouter-key
# OPENCODE_API_ENDPOINT=https://openrouter.ai/api/v1
# OPENCODE_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENCODE_FALLBACK_MODEL=mistralai/mistral-small-3.1-24b-instruct:free
# AI_PROVIDER_NAME=OpenRouter

# Groq example:
# OPENCODE_API_KEY=replace-with-your-groq-key
# OPENCODE_API_ENDPOINT=https://api.groq.com/openai/v1
# OPENCODE_MODEL=llama-3.3-70b-versatile
# OPENCODE_FALLBACK_MODEL=llama-3.1-8b-instant
# AI_PROVIDER_NAME=Groq

# Database names for each multisite
DRUPAL_DB_HOST=db
DRUPAL_DB_PORT=3306
DRUPAL_DB_USER=db
DRUPAL_DB_PASSWORD=db
DRUPAL_DB_PRIMARY=primary_db
DRUPAL_DB_SITE1=site1_db
DRUPAL_DB_SITE2=site2_db

# Optional translation endpoint
LIBRETRANSLATE_ENDPOINT=http://localhost:5000
